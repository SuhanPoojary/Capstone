<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="SafeReadyChip">
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:paddingTop">8dp</item>
        <item name="android:paddingBottom">8dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:fontFamily">@font/poppins_medium</item>
        <item name="android:gravity">center</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_width">wrap_content</item>
    </style>

    <style name="SafeReadyChipActive" parent="SafeReadyChip">
        <item name="android:background">@drawable/bg_chip_active</item>
        <item name="android:textColor">@color/white</item>
    </style>

    <style name="SafeReadyChipInactive" parent="SafeReadyChip">
        <item name="android:background">@drawable/bg_chip_inactive</item>
        <item name="android:textColor">@color/dashboard_greeting</item>
    </style>

</resources>
